{
  "manifest_version": 3,
  "name": "HH Auto Responder",
  "version": "1.0",
  "description": "Автоматические интеллектуальные отклики на вакансии HeadHunter",
  
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "sidePanel"
  ],
  
  "host_permissions": [
    "https://*.hh.ru/*",
    "https://hh.ru/*"
  ],
  
  "background": {
    "service_worker": "background/background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://*.hh.ru/*",
        "https://hh.ru/*"
      ],
      "js": [
        "content-scripts/logger.js",
        "content-scripts/vacancy-analyzer.js",
        "content-scripts/response-engine.js",
        "content-scripts/form-filler.js"
      ],
      "run_at": "document_end"
    }
  ],
  
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  
  "action": {
    "default_title": "Open HH Auto Responder"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png", 
    "128": "icons/icon128.png"
  }
}