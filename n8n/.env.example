POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=n8n

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=change_me_long_random_32plus_chars
GENERIC_TIMEZONE=Europe/Moscow

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# Chat auto-cycle mode: safe | full
AUTO_MODE=safe

# Adapter type: playwright | mock | http
CHAT_ADAPTER=playwright
HH_CHAT_URL=https://hh.ru/chat
COOKIES_PATH=./playwright/cookies.json
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_SLOWMO_MS=0
CHAT_POLL_URL=
CHAT_SEND_URL=
CHAT_API_TOKEN=

# AI settings
AI_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
RESUME_FILE=./chat-auto/resume-profile.md
CANDIDATE_NAME=Ваше Имя
CONTACT_TELEGRAM=@your_telegram
MIN_CONFIDENCE=0.65
SYSTEM_PROMPT=Ты помощник по переписке в HR-чате. Пиши коротко, вежливо, по делу.
RESPONSE_TEMPLATE=Здравствуйте! Спасибо за сообщение по вакансии "{{vacancyTitle}}". {{coreAnswer}}\n\nС уважением, {{candidateName}}

# Pipeline limits
MAX_REPLIES_PER_HOUR=30
MIN_SECONDS_BETWEEN_REPLIES=20
MAX_RETRIES=3
BASE_BACKOFF_MS=800
POLL_LIMIT=20

# File paths
AUTO_STATE_FILE=./chat-auto/state.json
AUTO_LOG_FILE=./chat-auto/automation-log.jsonl
REPORT_DIR=./chat-auto/reports
DRAFT_QUEUE_FILE=./chat-auto/drafts.json
MOCK_INBOX_FILE=./chat-auto/mock-inbox.json
MOCK_OUTBOX_FILE=./chat-auto/mock-outbox.json

# Alerts
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# Internal runner auth (used by n8n HTTP Request nodes)
RUNNER_AUTH_TOKEN=change_me_runner_token
