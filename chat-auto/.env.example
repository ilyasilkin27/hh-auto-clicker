# Mode: safe | full
AUTO_MODE=safe

# Adapter: playwright | mock | http
CHAT_ADAPTER=playwright

HH_CHAT_URL=https://hh.ru/chat
COOKIES_PATH=./playwright/cookies.json
PLAYWRIGHT_HEADED=false
PLAYWRIGHT_SLOWMO_MS=0

AUTO_STATE_FILE=./chat-auto/state.json
AUTO_LOG_FILE=./chat-auto/automation-log.jsonl
REPORT_DIR=./chat-auto/reports
DRAFT_QUEUE_FILE=./chat-auto/drafts.json

MOCK_INBOX_FILE=./chat-auto/mock-inbox.json
MOCK_OUTBOX_FILE=./chat-auto/mock-outbox.json

CHAT_POLL_URL=
CHAT_SEND_URL=
CHAT_API_TOKEN=

# AI: template | groq | openai
AI_PROVIDER=template
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
RESUME_FILE=./chat-auto/resume-profile.example.md
CANDIDATE_NAME=Ваше Имя
CONTACT_TELEGRAM=@your_telegram
CONTACT_EMAIL=you@example.com
CONTACT_GITHUB=https://github.com/your-username
PORTFOLIO_URL=https://your-portfolio.example.com
MIN_CONFIDENCE=0.65
SYSTEM_PROMPT=Ты пишешь в HR-чате от лица кандидата Ильи, в первом лице. Отвечай уверенно и по делу, с опорой на факты из резюме. Если просят анкету или тестовое, вежливо откажись и предложи перейти в Telegram.
RESPONSE_TEMPLATE=Здравствуйте! Спасибо за сообщение по вакансии "{{vacancyTitle}}". {{coreAnswer}}\n\nЕсли удобно, подскажите, пожалуйста: {{followupQuestion}}\n\nС уважением, Илья

MAX_REPLIES_PER_HOUR=30
MIN_SECONDS_BETWEEN_REPLIES=20
MAX_RETRIES=3
BASE_BACKOFF_MS=800
POLL_LIMIT=20
POLL_CHAT_LIST_ONLY=false
USE_CHATS_API_PAGINATION=true
CHATS_API_MAX_PAGES=20
CHAT_LIST_MAX_SCROLL_PASSES=80
CHAT_LIST_END_STREAK_TO_STOP=5
FORCE_ALL_CHATS_TAB=true
SKIP_YESTERDAY_CHATS=true
SKIP_REJECT_CHATS=true
ONLY_JS_STACK=true
SKIP_MANUAL_REVIEW=true

ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=
